FROM golang:1.26 AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /dockube-controller ./cmd/controller

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /dockube-controller /dockube-controller
ENTRYPOINT ["/dockube-controller"]
